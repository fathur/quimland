SECRET_KEY=django-insecure-change-me

DEBUG=True
ALLOWED_HOSTS=

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=quimland
DB_USER=psql
DB_PASSWORD=passwd
DB_HOST=localhost
DB_PORT=5432

# Media / Static
MEDIA_ROOT=
STATIC_ROOT=
SECURE_MEDIA_ROOT=   # defaults to <BASE_DIR>/secure_media — keep outside web root in production

# File storage — set to 'r2' to route uploads to Cloudflare R2
STORAGE_BACKEND=local

# Cloudflare R2 (required when STORAGE_BACKEND=r2)
R2_BUCKET_NAME=
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_CUSTOM_DOMAIN=
